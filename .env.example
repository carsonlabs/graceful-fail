# Database (Railway provides this automatically)
DATABASE_URL=mysql://user:password@host:3306/graceful_fail

# JWT Session Secret (generate a random string)
JWT_SECRET=your-random-secret-here

# GitHub OAuth (create at github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App URL (your production domain)
APP_URL=https://selfheal.dev

# OpenAI (for LLM error analysis)
OPENAI_API_KEY=sk-...
# Optional: override model (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
# Optional: override base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com

# Stripe (for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Owner (your GitHub user ID — gets admin role)
OWNER_OPEN_ID=github_YOUR_GITHUB_USER_ID

# App ID
VITE_APP_ID=graceful-fail

# === x402 Payment Protocol (outcome-based pricing) ===
# Your USDC wallet address (Base or Solana) — leave blank to disable x402
X402_RECEIVING_WALLET=
# x402 facilitator for verify/settle
X402_FACILITATOR_URL=https://x402.org/facilitator
# Supported networks (comma-separated: base-sepolia | base)
# NOTE: the loader matches literal names — NOT the "eip155:<chainId>" format.
X402_NETWORKS=base-sepolia
# Set to "true" for testnet
X402_TESTNET=true
# Payment deadline in seconds
X402_DEADLINE_SECONDS=300
# Custom pricing tiers (optional JSON override)
# X402_PRICING_CONFIG='[{"name":"simple","basePrice":0.001,"maxPrice":0.002,"patterns":["400","404"]},{"name":"complex","basePrice":0.003,"maxPrice":0.005,"patterns":["429","403"]}]'

# === Alerts & Monitoring ===
# Slack/Discord/generic webhook for alerts
ALERT_WEBHOOK_URL=
# Alert when traffic > 5x baseline
ALERT_TRAFFIC_SPIKE_MULTIPLIER=5
# Alert when daily LLM cost > $10
ALERT_MAX_DAILY_LLM_COST=10
# Alert when heal success < 90%
ALERT_MIN_HEAL_SUCCESS_RATE=0.9
# Alert check interval (1 min)
ALERT_CHECK_INTERVAL_MS=60000

# === selfheal v2 — Compliance Module ===
# Right-to-erasure cascade for AI agent stacks. The compliance router only
# mounts when SELFHEAL_API_KEY (or SELFHEAL_API_KEYS) is set. If the API key is
# present but no adapters are configured below, the server fails fast at
# startup rather than running with a broken config.

# Bearer-token allowlist. Either a single key or a comma-separated list.
SELFHEAL_API_KEY=

# HMAC secret for the audit log. Generate with: openssl rand -hex 32
# Defaults to a derivation of SELFHEAL_API_KEY — set explicitly in production.
SELFHEAL_AUDIT_SECRET=

# Postgres adapter — primary user-data store. Apply the migration first:
#   psql $SELFHEAL_PG_URL -f node_modules/@selfheal/core/migrations/001_compliance_init.sql
SELFHEAL_PG_URL=
SELFHEAL_PG_RULES='[{"table":"messages","userIdColumn":"user_id"}]'

# pgvector adapter — RAG embeddings. Reuses SELFHEAL_PG_URL if not specified.
SELFHEAL_PGVECTOR_TABLE=
SELFHEAL_PGVECTOR_USER_COLUMN=user_id
# SELFHEAL_PGVECTOR_URL=

# Pinecone adapter — vector DB.
SELFHEAL_PINECONE_API_KEY=
SELFHEAL_PINECONE_INDEX=
SELFHEAL_PINECONE_METADATA_KEY=user_id

# Set to "false" to use in-memory stores instead of persisting via SqlAuditStore
# / SqlHistoryStore. Dev/test only — production should always persist.
# SELFHEAL_PERSIST=false
