# Database (Railway provides this automatically)
DATABASE_URL=mysql://user:password@host:3306/graceful_fail

# JWT Session Secret (generate a random string)
JWT_SECRET=your-random-secret-here

# GitHub OAuth (create at github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App URL (your production domain)
APP_URL=https://selfheal.dev

# OpenAI (for LLM error analysis)
OPENAI_API_KEY=sk-...
# Optional: override model (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
# Optional: override base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com

# Stripe (for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Owner (your GitHub user ID — gets admin role)
OWNER_OPEN_ID=github_YOUR_GITHUB_USER_ID

# App ID
VITE_APP_ID=graceful-fail
