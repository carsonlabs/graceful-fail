{
	"name": "n8n-nodes-graceful-fail",
	"version": "0.1.0",
	"description": "n8n community node for Graceful Fail — AI-powered API error recovery proxy",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"graceful-fail",
		"api-proxy",
		"error-recovery",
		"ai-agents",
		"self-healing"
	],
	"license": "MIT",
	"homepage": "https://selfheal.dev",
	"author": {
		"name": "Carson Labs",
		"url": "https://selfheal.dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/carsonlabs/n8n-nodes-graceful-fail.git"
	},
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"lint": "eslint src/**/*.ts",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/GracefulFailApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/GracefulFail/GracefulFail.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^1.0.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
