{
  "name": "@selfheal/core",
  "version": "0.1.0",
  "description": "Core engine for selfheal compliance: cascade orchestrator, HMAC-chained tamper-evident audit log, deletion-proof builder, and the three reference adapters (Postgres, pgvector, Pinecone).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://selfheal.dev/compliance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carsonlabs/graceful-fail.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/carsonlabs/graceful-fail/issues",
  "keywords": [
    "gdpr",
    "ccpa",
    "right-to-erasure",
    "compliance",
    "ai-agents",
    "audit-log",
    "hmac",
    "selfheal"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.5",
    "pg-mem": "^3.0.14",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.4"
  }
}
