{
  "name": "@selfheal/sdk",
  "version": "0.1.0",
  "description": "Production-grade right-to-erasure for AI agent stacks. One API, full audit trail, MCP-native. Cascade GDPR/CCPA deletion across Postgres, pgvector, Pinecone — with a tamper-evident signed audit log.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://selfheal.dev/compliance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carsonlabs/graceful-fail.git",
    "directory": "packages/sdk"
  },
  "bugs": "https://github.com/carsonlabs/graceful-fail/issues",
  "keywords": [
    "gdpr",
    "ccpa",
    "ca-delete-act",
    "right-to-erasure",
    "compliance",
    "ai-agents",
    "selfheal",
    "sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@selfheal/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.4"
  }
}
